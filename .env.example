# ─── Servidor ─────────────────────────────────────────────────────────────────
# Nota: o gateway aponta para esta porta (NOTIFICATION_SERVICE_URL)
PORT=3002
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Base de dados (PostgreSQL via Prisma) ────────────────────────────────────
DATABASE_URL=postgresql://ebooks:ebooks_secret@localhost:5432/notification_db

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://ebooks:ebooks_secret@localhost:5672

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ebooks.co.mz
SMTP_PASS=password_do_smtp
SMTP_FROM=EBooksStore <noreply@ebooks.co.mz>
